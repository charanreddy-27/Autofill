{
  "manifest_version": 3,
  "name": "Autofill Vault",
  "version": "1.0.0",
  "description": "Store your personal details and accounts in one place, copy any value in a click, and autofill forms automatically.",
  "permissions": ["storage", "activeTab", "scripting", "contextMenus", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Autofill Vault",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "src/dashboard.html",
    "open_in_tab": true
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/common.js", "src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "commands": {
    "fill-page": {
      "suggested_key": { "default": "Alt+Shift+F" },
      "description": "Autofill the current page"
    },
    "_execute_action": {
      "suggested_key": { "default": "Alt+Shift+V" },
      "description": "Open the Autofill Vault popup"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
